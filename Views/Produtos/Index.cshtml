@model IEnumerable<LojaMVC.Models.Produto>

@{
    ViewData["Title"] = "Administrar Produtos";
}

<div class="admin-header">
    <h1>⚙️ Administrar Produtos</h1>
    <a asp-action="Create" class="btn-azul">+ Novo Produto</a>
</div>

<form asp-action="Index" method="get" class="busca-form">
    <input type="text" name="buscaNome" placeholder="🔍 Buscar por nome..." value="@ViewData["BuscaNome"]" />
    <input type="text" name="buscaCategoria" placeholder="📂 Buscar por categoria..." value="@ViewData["BuscaCategoria"]" />
    <button type="submit" class="btn-azul">Buscar</button>
    <a asp-action="Index" class="btn-secundario">Limpar</a>
</form>

<div class="tabela-admin">
    <table class="table table-borderless mb-0">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Categoria</th>
                <th>Preço</th>
                <th>Estoque</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Nome</strong></td>
                    <td><span style="background:var(--azul-claro);color:var(--azul-escuro);padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;">@item.Categoria</span></td>
                    <td style="font-weight:600;color:var(--azul-escuro);">R$ @item.Preco.ToString("F2")</td>
                    <td>@item.Estoque un.</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">✏️ Editar</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">👁️ Detalhes</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">🗑️ Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Any())
    {
        <div class="sem-resultado">
            <p>Nenhum produto cadastrado ainda.</p>
        </div>
    }
</div>