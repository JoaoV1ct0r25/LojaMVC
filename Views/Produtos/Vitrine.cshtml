@model IEnumerable<LojaMVC.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<h1 class="text-center mb-4">Nossos Produtos</h1>

<form asp-action="Vitrine" method="get" class="row mb-4">
    <div class="col-md-4">
        <input type="text" name="buscaNome" class="form-control" placeholder="Buscar por nome..." value="@ViewData["BuscaNome"]" />
    </div>
    <div class="col-md-4">
        <input type="text" name="buscaCategoria" class="form-control" placeholder="Buscar por categoria..." value="@ViewData["BuscaCategoria"]" />
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-primary">Pesquisar</button>
        <a asp-action="Vitrine" class="btn btn-secondary">Limpar</a>
    </div>
</form>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(item.ImagemUrl))
                {
                    <img src="@item.ImagemUrl" class="card-img-top" alt="@item.Nome" style="height:200px;object-fit:cover;" />
                }
                <div class="card-body">
                    <h5 class="card-title">@item.Nome</h5>
                    <p class="card-text">@item.Descricao</p>
                    <p class="card-text"><strong>R$ @item.Preco.ToString("F2")</strong></p>
                    <span class="badge bg-secondary">@item.Categoria</span>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <p class="text-center text-muted">Nenhum produto encontrado.</p>
}