@model IEnumerable<LojaMVC.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<div class="secao-titulo">
    <p class="secao-label">Catálogo</p>
    <h2>Nossos Produtos</h2>
</div>

<form asp-action="Vitrine" method="get" class="busca-form">
    <input type="text" name="buscaNome" placeholder="🔍 Buscar por nome..." value="@ViewData["BuscaNome"]" />
    <input type="text" name="buscaCategoria" placeholder="📂 Buscar por categoria..." value="@ViewData["BuscaCategoria"]" />
    <button type="submit" class="btn-azul">Buscar</button>
    <a asp-action="Vitrine" class="btn-secundario">Limpar</a>
</form>

@if (!Model.Any())
{
    <div class="sem-resultado">
        <p>😕 Nenhum produto encontrado.</p>
    </div>
}
else
{
    <div class="produto-grid">
        @foreach (var item in Model)
        {
            <div class="produto-card">
                <div class="produto-card-imagem">
                    @if (!string.IsNullOrEmpty(item.ImagemUrl))
                    {
                        <img src="@item.ImagemUrl" alt="@item.Nome" />
                    }
                    else
                    {
                        <span class="sem-imagem">📦</span>
                    }
                </div>
                <div class="produto-card-body">
                    <p class="produto-card-categoria">@item.Categoria</p>
                    <p class="produto-card-nome">@item.Nome</p>
                    <p class="produto-card-descricao">@item.Descricao</p>
                    <p class="produto-card-preco">R$ @item.Preco.ToString("F2")</p>
                </div>
            </div>
        }
    </div>
}