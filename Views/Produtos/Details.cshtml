@model LojaMVC.Models.Produto

@{
    ViewData["Title"] = "Detalhes do Produto";
}

<div class="form-container">
    <h1>👁️ Detalhes do Produto</h1>

    @if (!string.IsNullOrEmpty(Model.ImagemUrl))
    {
        <img src="@Model.ImagemUrl" class="img-fluid mb-4" alt="@Model.Nome" style="border-radius:10px;max-height:280px;width:100%;object-fit:cover;" />
    }

    <div style="background:var(--azul-claro);border-radius:10px;padding:24px;margin-bottom:28px;">
        <dl class="row mb-0">
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Descrição</dt>
            <dd class="col-sm-8">@Model.Descricao</dd>
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Preço</dt>
            <dd class="col-sm-8" style="font-weight:700;color:var(--azul-escuro);">R$ @Model.Preco.ToString("F2")</dd>
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Categoria</dt>
            <dd class="col-sm-8"><span style="background:var(--azul-medio);color:white;padding:3px 12px;border-radius:20px;font-size:13px;">@Model.Categoria</span></dd>
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Estoque</dt>
            <dd class="col-sm-8">@Model.Estoque un.</dd>
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Cadastrado em</dt>
            <dd class="col-sm-8 mb-0">@Model.DataCadastro.ToString("dd/MM/yyyy")</dd>
        </dl>
    </div>

    <div style="display:flex;gap:12px;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-azul">✏️ Editar</a>
        <a asp-action="Index" class="btn-secundario">Voltar</a>
    </div>
</div>