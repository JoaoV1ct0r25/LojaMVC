@model LojaMVC.Models.Produto

@{
    ViewData["Title"] = "Excluir Produto";
}

<div class="form-container">
    <h1>🗑️ Excluir Produto</h1>
    <p style="color:var(--texto-suave);margin-bottom:28px;">Tem certeza que deseja excluir este produto? Esta ação não pode ser desfeita.</p>

    <div style="background:var(--azul-claro);border-radius:10px;padding:24px;margin-bottom:28px;">
        <dl class="row mb-0">
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Categoria</dt>
            <dd class="col-sm-8">@Model.Categoria</dd>
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Preço</dt>
            <dd class="col-sm-8">R$ @Model.Preco.ToString("F2")</dd>
            <dt class="col-sm-4" style="color:var(--azul-escuro);font-weight:600;">Estoque</dt>
            <dd class="col-sm-8 mb-0">@Model.Estoque un.</dd>
        </dl>
    </div>

    <form asp-action="Delete" style="display:flex;gap:12px;">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">🗑️ Confirmar Exclusão</button>
        <a asp-action="Index" class="btn-secundario">Cancelar</a>
    </form>
</div>