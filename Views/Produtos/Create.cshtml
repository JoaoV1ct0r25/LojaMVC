@model LojaMVC.Models.Produto

@{
    ViewData["Title"] = "Novo Produto";
}

<div class="form-container">
    <h1>➕ Novo Produto</h1>
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group mb-3">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" class="form-control" placeholder="Nome do produto" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Descricao"></label>
            <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Descrição do produto"></textarea>
            <span asp-validation-for="Descricao" class="text-danger small"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Preco"></label>
            <input asp-for="Preco" class="form-control" placeholder="0,00" />
            <span asp-validation-for="Preco" class="text-danger small"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Categoria"></label>
            <input asp-for="Categoria" class="form-control" placeholder="Ex: Eletrônicos, Roupas..." />
            <span asp-validation-for="Categoria" class="text-danger small"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Estoque"></label>
            <input asp-for="Estoque" class="form-control" placeholder="0" />
            <span asp-validation-for="Estoque" class="text-danger small"></span>
        </div>
        <div class="form-group mb-4">
            <label asp-for="ImagemUrl"></label>
            <input asp-for="ImagemUrl" class="form-control" placeholder="https://..." />
            <span asp-validation-for="ImagemUrl" class="text-danger small"></span>
        </div>
        <div style="display:flex;gap:12px;">
            <button type="submit" class="btn-azul">Criar Produto</button>
            <a asp-action="Index" class="btn-secundario">Voltar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}