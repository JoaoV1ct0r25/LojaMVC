@{
    ViewData["Title"] = "Contato";
}

<div class="pagina-conteudo">
    <h1>Contato</h1>
    <p class="subtitulo">Entre em contato com a nossa loja. Respondemos rapidamente por e-mail ou telefone.</p>

    <div class="contato-item">
        <span class="contato-icon">✉️</span>
        <div>
            <p class="contato-label">E-mail</p>
            <p class="contato-valor">contato@lojamvc.com</p>
        </div>
    </div>

    <div class="contato-item">
        <span class="contato-icon">📞</span>
        <div>
            <p class="contato-label">Telefone</p>
            <p class="contato-valor">(61) 99999-9999</p>
        </div>
    </div>

    <div class="contato-item">
        <span class="contato-icon">📍</span>
        <div>
            <p class="contato-label">Endereço</p>
            <p class="contato-valor">Av. Exemplo, 123 — Luziânia, GO</p>
        </div>
    </div>
</div>