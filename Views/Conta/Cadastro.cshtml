@{
    ViewData["Title"] = "Cadastro";
}

<div class="form-container">
    <h1>📝 Criar Conta</h1>

    @if (ViewBag.Erros != null)
    {
        <div class="alert alert-danger">
            @foreach (var erro in ViewBag.Erros)
            {
                <p class="mb-0">@erro</p>
            }
        </div>
    }

    <form asp-action="Cadastro" method="post">
        <div class="form-group mb-3">
            <label>Nome Completo</label>
            <input type="text" name="nomeCompleto" class="form-control" placeholder="Seu nome completo" required />
        </div>
        <div class="form-group mb-3">
            <label>E-mail</label>
            <input type="email" name="email" class="form-control" placeholder="seu@email.com" required />
        </div>
        <div class="form-group mb-4">
            <label>Senha <span style="font-size:12px;color:var(--texto-suave);">(mínimo 6 caracteres com número)</span></label>
            <input type="password" name="senha" class="form-control" placeholder="••••••" required />
        </div>
        <div style="display:flex;gap:12px;align-items:center;">
            <button type="submit" class="btn-azul">Criar Conta</button>
            <a asp-action="Login" style="font-size:14px;color:var(--azul-medio);">Já tenho conta</a>
        </div>
    </form>
</div>